# ── Server ────────────────────────────────────────────────────────────────
PORT=8787
LOG_LEVEL=info
MAX_REQUEST_BYTES=1048576

# ── LLM Provider (OpenAI-compatible; one adapter serves OpenAI/Ollama/MLX) ──
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
#   EMBEDDING_MODEL=text-embedding-3-small
# Ollama (local): point base URL at Ollama's OpenAI-compatible endpoint.
# NOTE: a chat model cannot serve /v1/embeddings — pull a dedicated embedding model.
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen3.6:35b-a3b         # fast MoE (3B active) — good for the many-call consolidation path
#   LLM_API_KEY=ollama                # any non-empty string; Ollama ignores it
#   EMBEDDING_MODEL=qwen3-embedding:8b # or nomic-embed-text as a lighter fallback
#
# MLX chat (mlx_lm.server) + Ollama embeddings: mlx_lm.server has no /v1/embeddings,
# so split embeddings onto Ollama via EMBEDDING_BASE_URL.
#   Serve gemma:  mlx_lm.server --model mlx-community/gemma-4-31b-it-8bit --port 8080
#   LLM_BASE_URL=http://127.0.0.1:8080/v1
#   LLM_MODEL=mlx-community/gemma-4-31b-it-8bit   # reasoning model: reply text is in message.content, thinking in message.reasoning
#   LLM_API_KEY=not-needed
#   EMBEDDING_BASE_URL=http://localhost:11434/v1
#   EMBEDDING_API_KEY=ollama
#   EMBEDDING_MODEL=qwen3-embedding:8b
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_REQUEST_TIMEOUT_MS=300000
# EMBEDDING_BASE_URL=       # optional; only when embeddings use a different endpoint than chat
# EMBEDDING_API_KEY=

# ── Memory retrieval (Generative-Agents weighted scoring) ───────────────────
MEMORY_RETRIEVE_TOP_K=6
MEMORY_RECENCY_DECAY=0.99
MEMORY_WEIGHT_RECENCY=1
MEMORY_WEIGHT_IMPORTANCE=1
MEMORY_WEIGHT_RELEVANCE=1

# ── Autonomous reflection (importance-triggered self-learning) ──────────────
# Reflect once accumulated observation importance crosses the threshold.
REFLECTION_IMPORTANCE_THRESHOLD=25
REFLECTION_RECENT_N=20
REFLECTION_QUESTIONS_PER_PASS=3
REFLECTIONS_PER_QUESTION=2
REFLECTION_IMPORTANCE=7
# MemGPT-style core block size (chars)
CORE_MEMORY_CHAR_LIMIT=2000
# Consolidate quiet conversation once this many uncovered user/assistant turns accumulate.
CONSOLIDATION_SUMMARY_TURN_THRESHOLD=8

# ── Persistence adapters ────────────────────────────────────────────────────
# "stub" uses built-in memory. Any other name requires OPOD_ADAPTER_MODULE.
# STORE_DRIVER=stub | postgres | <deployment-defined>
STORE_DRIVER=stub
# Module package/path exporting createAdapters(env); relative paths use process cwd.
# OPOD_ADAPTER_MODULE=./deployment/adapters.js
# Bearer token for POST /memory/consolidate (16+ chars); required for every non-stub driver.
# OPOD_WORKER_TOKEN=replace-with-a-long-random-token
# DATABASE_URL=postgres://user:pass@localhost:5432/opod

# ── Tools ───────────────────────────────────────────────────────────────────
# Server-side tool loop: get_time, get_weather via Open-Meteo — no key needed.
TOOLS_ENABLED=true
# web_search tool registers only when a Tavily key is set.
# WEB_SEARCH_API_KEY=
# WEB_SEARCH_BASE_URL=https://api.tavily.com
