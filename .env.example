# ── Server ────────────────────────────────────────────────────────────────
PORT=8787
LOG_LEVEL=info

# ── LLM Provider (OpenAI-compatible; same adapter serves OpenAI and Ollama) ──
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
#   EMBEDDING_MODEL=text-embedding-3-small
# Ollama (local): point base URL at Ollama's OpenAI-compatible endpoint.
# NOTE: a chat model cannot serve /v1/embeddings — pull a dedicated embedding model.
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=qwen3.6:35b-a3b         # fast MoE (3B active) — good for the many-call consolidation path
#   LLM_API_KEY=ollama                # any non-empty string; Ollama ignores it
#   EMBEDDING_MODEL=qwen3-embedding:8b # or nomic-embed-text as a lighter fallback
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Memory retrieval (Generative-Agents weighted scoring) ───────────────────
MEMORY_RETRIEVE_TOP_K=6
MEMORY_RECENCY_DECAY=0.99
MEMORY_WEIGHT_RECENCY=1
MEMORY_WEIGHT_IMPORTANCE=1
MEMORY_WEIGHT_RELEVANCE=1

# ── Autonomous reflection (importance-triggered self-learning) ──────────────
# Reflect once accumulated observation importance crosses the threshold.
REFLECTION_IMPORTANCE_THRESHOLD=25
REFLECTION_RECENT_N=20
REFLECTION_QUESTIONS_PER_PASS=3
REFLECTION_INSIGHTS_PER_QUESTION=2
REFLECTION_IMPORTANCE=7
# MemGPT-style core block size (chars)
CORE_MEMORY_CHAR_LIMIT=2000

# ── Persist layer (deferred; stubs used until a Postgres adapter lands) ──────
# STORE_DRIVER=stub | postgres
STORE_DRIVER=stub
# DATABASE_URL=postgres://user:pass@localhost:5432/opod
